def _dex(args, stdin=None):
    print("Stopping firewalld")
    subprocess.run(["sudo", "systemctl", "stop", "firewalld"], check=False)
    print("Launching scrcpy")
    subprocess.run(["scrcpy", "--fullscreen", "--new-display=1920x1200/180", "-S", "--max-fps=60", "--mouse=uhid"], check=False)
    print("Killing adb..")
    subprocess.run(["adb", "kill-server"], check=False)
    print("Starting firewalld")
    subprocess.run(["sudo", "systemctl", "start", "firewalld"], check=False)
    return 0


aliases["dex"] = _dex
