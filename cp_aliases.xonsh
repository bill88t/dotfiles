import os
import re
import shlex
import subprocess
import time
from pathlib import Path

ESP_EXPORT_SCRIPTS = {
    "espload": Path("~/git/esp-idf-v5.5.3/export.sh").expanduser(),
    "esp6load": Path("~/git/esp-idf-v6.0.1/export.sh").expanduser(),
}

_ESP_ENV_CACHE = {}
_NUM_CPUS = os.cpu_count() or 1


def _load_env_from_export_script(script_path):
    script_path = Path(script_path).expanduser()
    if not script_path.is_file():
        return None
    proc = subprocess.run(
        ["/bin/sh", "-lc", f". {shlex.quote(str(script_path))} >/dev/null 2>&1; env -0"],
        capture_output=True,
        text=False,
        check=False,
    )
    if proc.returncode != 0:
        return None
    env = {}
    for chunk in proc.stdout.split(b"\0"):
        if not chunk or b"=" not in chunk:
            continue
        key, value = chunk.split(b"=", 1)
        env[key.decode(errors="ignore")] = value.decode(errors="ignore")
    return env


def _activate_esp_env(alias_name):
    script = ESP_EXPORT_SCRIPTS.get(alias_name)
    if script is None:
        print(f"Unknown ESP export alias: {alias_name}")
        return 1
    cache_key = str(script)
    env = _ESP_ENV_CACHE.get(cache_key)
    if env is None:
        env = _load_env_from_export_script(script)
        if env is None:
            print(f"Failed to load ESP-IDF environment from: {script}")
            return 1
        _ESP_ENV_CACHE[cache_key] = env
    for k, v in env.items():
        __xonsh__.env[k] = v
    return 0


def _make_env_alias(alias_name):
    def _runner(args, stdin=None):
        return _activate_esp_env(alias_name)

    return _runner


aliases["espload"] = _make_env_alias("espload")
aliases["esp6load"] = _make_env_alias("esp6load")


def _wait_for_device(path):
    while not Path(path).exists():
        print("Waiting for board..")
        time.sleep(1)


def _chip_id(port, no_reset=False):
    rc = _activate_esp_env("espload")
    if rc != 0:
        return rc
    _wait_for_device(port)
    cmd = ["esptool.py", "--port", port]
    if no_reset:
        cmd.extend(["--before", "no_reset", "--after", "no_reset"])
    cmd.append("chip_id")
    return subprocess.run(cmd, check=False).returncode


aliases["utio-chipid"] = (lambda args, stdin=None: _chip_id("/dev/ttyUSB0", no_reset=False))
aliases["utio-bchipid"] = (lambda args, stdin=None: _chip_id("/dev/ttyUSB0", no_reset=True))
aliases["atio-chipid"] = (lambda args, stdin=None: _chip_id("/dev/ttyACM0", no_reset=False))
aliases["atio-bchipid"] = (lambda args, stdin=None: _chip_id("/dev/ttyACM0", no_reset=True))


def _find_mount_by_label(label_hint):
    proc = subprocess.run(
        ["lsblk", "-o", "LABEL,MOUNTPOINT", "-nr"],
        capture_output=True,
        text=True,
        check=False,
    )
    if proc.returncode != 0:
        return ""
    for line in proc.stdout.splitlines():
        parts = line.split(None, 1)
        if len(parts) != 2:
            continue
        label, mountpoint = parts
        if label_hint in label and mountpoint:
            return mountpoint.strip()
    return ""


def _cp_make(board, debug=False, clean=False):
    cmd = ["make"]
    if not clean:
        cmd.extend([f"-j{_NUM_CPUS}", "V=steps rules"])
    else:
        cmd.extend(["V=0"])
    cmd.append(f"BOARD={board}")
    if clean:
        cmd.append("clean")
    if debug and not clean:
        cmd.append("DEBUG=1")
    return subprocess.run(cmd, check=False).returncode


def _cp_make_clean_then_build(board, debug=False):
    rc = subprocess.run(["make", f"-j{_NUM_CPUS}", "V=steps rules", f"BOARD={board}", "clean"], check=False).returncode
    if rc != 0:
        return rc
    cmd = ["make", f"-j{_NUM_CPUS}", "V=steps rules", f"BOARD={board}"]
    if debug:
        cmd.append("DEBUG=1")
    return subprocess.run(cmd, check=False).returncode


def _cp_load_uf2(board, boot_label):
    mountpoint = _find_mount_by_label(boot_label)
    if not mountpoint:
        print(f"Could not find mounted UF2 drive matching label: {boot_label}")
        return 1
    fw = Path(f"build-{board}") / "firmware.uf2"
    if not fw.is_file():
        print(f"Missing firmware: {fw}")
        return 1
    print("Loading..")
    rc = subprocess.run(["cp", str(fw), str(Path(mountpoint) / "firmware.uf2")], check=False).returncode
    if rc == 0:
        subprocess.run(["sync"], check=False)
    return rc


def _cp_flash(board, chip, baud, port, ff, fm, before_no_reset=False, erase=False, raw_args=None):
    rc = _activate_esp_env("espload")
    if rc != 0:
        return rc
    _wait_for_device(port)
    if erase:
        cmd = ["esptool.py", "--after", "no_reset", "-c", chip]
        if before_no_reset:
            cmd.extend(["--before", "no_reset", "--after", "no_reset"])
        cmd.extend(["-p", port, "-b", str(baud), "erase_flash"])
        return subprocess.run(cmd, check=False).returncode

    cmd = ["esptool.py", "-c", chip]
    if before_no_reset:
        cmd.extend(["--before", "no_reset", "--after", "no_reset"])
    cmd.extend(["-p", port, "-b", str(baud), "write_flash", "-fm", fm, "-ff", ff, "0x0"])
    if raw_args:
        cmd.extend(raw_args)
    else:
        cmd.append(f"build-{board}/firmware.bin")
    return subprocess.run(cmd, check=False).returncode


def _cp_dump(board, chip, baud, port):
    rc = _activate_esp_env("espload")
    if rc != 0:
        return rc
    size_proc = subprocess.run(
        ["esptool.py", "-b", str(baud), "-p", port, "flash_id"],
        capture_output=True,
        text=True,
        check=False,
    )
    if size_proc.returncode != 0:
        return size_proc.returncode
    size_hex = ""
    for line in size_proc.stdout.splitlines():
        if "flash size:" in line:
            m = re.search(r"(\d+)\s*MB", line)
            if m:
                size_hex = hex(int(m.group(1)) * 1024 * 1024)
            break
    if not size_hex:
        size_hex = "0x400000"
    return subprocess.run(
        ["esptool.py", "-c", chip, "-b", str(baud), "-p", port, "read_flash", "0x0", size_hex, "backup.bin"],
        check=False,
    ).returncode


def _register_make_aliases(prefix, board, mode, chip="", baud="", port="", ff="", fm="", boot_label=""):
    def _mk(action):
        def _runner(args, stdin=None):
            rc = _activate_esp_env("espload")
            if rc != 0:
                return rc
            if action == "m":
                return _cp_make(board, debug=False, clean=False)
            if action == "c":
                return _cp_make(board, clean=True)
            if action == "cm":
                return _cp_make_clean_then_build(board, debug=False)
            if action == "dm":
                return _cp_make(board, debug=True, clean=False)
            if action == "dcm":
                return _cp_make_clean_then_build(board, debug=True)
            if action == "l":
                return _cp_load_uf2(board, boot_label)
            if action == "f":
                print("Flashing..")
                return _cp_flash(board, chip, baud, port, ff, fm, before_no_reset=False)
            if action == "bf":
                print("Flashing..")
                return _cp_flash(board, chip, baud, port, ff, fm, before_no_reset=True)
            if action == "df":
                print("Flashing..")
                return _cp_flash(board, chip, baud, port, ff, fm, before_no_reset=False, raw_args=args)
            if action == "bdf":
                print("Flashing..")
                return _cp_flash(board, chip, baud, port, ff, fm, before_no_reset=True, raw_args=args)
            if action == "w":
                print("Wiping..")
                return _cp_flash(board, chip, baud, port, ff, fm, erase=True)
            if action == "bw":
                print("Wiping..")
                return _cp_flash(board, chip, baud, port, ff, fm, before_no_reset=True, erase=True)
            if action == "gdb":
                return subprocess.run(
                    ["gdb", "-ex", "target extended-remote localhost:3333", f"build-{board}/firmware.elf"],
                    check=False,
                ).returncode
            if action == "dump":
                return _cp_dump(board, chip, baud, port)
            return 1

        return _runner

    for action in ("m", "c", "cm", "dm", "dcm", "gdb", "dump"):
        aliases[f"{prefix}-{action}"] = _mk(action)
    if mode in ("both", "uf2"):
        aliases[f"{prefix}-l"] = _mk("l")
    if mode in ("both", "flash"):
        for action in ("f", "bf", "df", "bdf", "w", "bw"):
            aliases[f"{prefix}-{action}"] = _mk(action)


