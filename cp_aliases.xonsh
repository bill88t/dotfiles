def _ffmpeg_wav(args, stdin=None):
    if len(args) < 2:
        print("Usage: ffmpeg_wav <input.mp3> <output.wav> [additional ffmpeg options]")
        return 1
    input_file = args[0]
    output_file = args[1]
    extra = args[2:]
    cmd = [
        "ffmpeg",
        "-i",
        input_file,
        "-bitexact",
        "-acodec",
        "pcm_s16le",
        "-ac",
        "1",
        "-ar",
        "16000",
        "-map_metadata",
        "-1",
        "-bitexact",
        *extra,
        output_file,
    ]
    return subprocess.run(cmd, check=False).returncode


aliases["ffmpeg_wav"] = _ffmpeg_wav
