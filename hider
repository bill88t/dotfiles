#!/usr/bin/env python3

import sys
import random

BLOCK_CHARS = ["в–€", "рњґљ", "рњґ‘", "рњґ“", "рњґ’", "рњґ‹", "рњґ„", "рњґЂ", "рњґ‚"]

# characters that should remain untouched
KEEP = {".", ",", "!", "?", " ", "\n", "\t"}

def transform(text: str) -> str:
    out = []
    for c in text:
        if c in KEEP:
            out.append(c)
        else:
            out.append(random.choice(BLOCK_CHARS))
    return "".join(out)

def main():
    print("Enter text (Ctrl+D to exit):")
    for line in sys.stdin:
        sys.stdout.write(transform(line))

if __name__ == "__main__":
    main()
