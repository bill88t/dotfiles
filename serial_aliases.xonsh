aliases["lstty"] = "/bin/ls /dev/ttyACM* /dev/ttyUSB* /dev/ttyS* 2>/dev/null"
aliases["atio"] = "tio /dev/ttyACM0"
aliases["atio1"] = "tio /dev/ttyACM1"
aliases["atio2"] = "tio /dev/ttyACM2"
aliases["stio"] = "tio /dev/ttyS0"
aliases["stio1"] = "tio /dev/ttyS1"
aliases["stio2"] = "tio /dev/ttyS2"
aliases["utio"] = "tio /dev/ttyUSB0"
aliases["utio1"] = "tio /dev/ttyUSB1"
aliases["utio2"] = "tio /dev/ttyUSB2"
aliases["picoprog"] = "flashprog -p serprog:dev=/dev/ttyACM1:115200,spispeed=12M"
